---
import Base from "../layouts/Base.astro";
---

<Base title="Page Not Found - Corner Store">
  <main class="page">
    <div class="content">
      <h1>Page not found.</h1>
      <p>The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="link">Back to store</a>
    </div>
  </main>
</Base>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .content {
    text-align: center;
    padding: 2rem 1.5rem;
    max-width: 480px;
  }

  .content h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .content p {
    color: #555;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .link {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.15s ease;
  }

  .link:hover {
    background: #333;
  }

  .link:focus-visible {
    outline: 2px solid #1a1a1a;
    outline-offset: 2px;
  }
</style>
