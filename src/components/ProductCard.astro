---
import type { Listing } from "../lib/storefront";
import { listingHasPrice, rawPriceToDecimal } from "../lib/storefront";

interface Props {
  listing: Listing;
}

const { listing } = Astro.props;
const hasPrice = listingHasPrice(listing);
---

<article class="product-card" itemscope itemtype="https://schema.org/Product">
  <figure>
    {
      listing.image ? (
        <img src={listing.image} alt={listing.imageAlt} itemprop="image" />
      ) : (
        <div class="placeholder" aria-label={listing.imageAlt} />
      )
    }
  </figure>
  <div>
    <h2 itemprop="name">{listing.name}</h2>
    {listing.description && <p itemprop="description">{listing.description}</p>}
    {hasPrice && (
      <p itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <data value={String(rawPriceToDecimal(listing.rawPrice!, listing.currency!))} itemprop="price" aria-label={"Price: " + listing.price}>{listing.price}</data>
        <meta itemprop="priceCurrency" content={listing.currency!.toUpperCase()} />
      </p>
    )}
    <a href={listing.paymentLink} aria-label={`Buy ${listing.name} on Stripe`} itemprop="url">Buy {listing.name}</a>
  </div>
</article>

<style>
  .product-card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease;
  }

  .product-card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .product-card figure {
    margin: 0;
  }

  .product-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #e5e5e5;
  }

  .product-card > div {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  [itemprop="name"] {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  [itemprop="description"] {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
  }

  [itemprop="offers"] {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: auto;
  }

  [itemprop="url"] {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.625rem 1.25rem;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-align: center;
    transition: background 0.15s ease;
  }

  [itemprop="url"]:hover {
    background: #333;
  }

  [itemprop="url"]:focus-visible {
    outline: 2px solid #1a1a1a;
    outline-offset: 2px;
  }
</style>
