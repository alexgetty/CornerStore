---
interface Product {
  name: string;
  description: string | null;
  image: string | null;
  imageAlt: string;
  price: string;
  paymentLink: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const rawPrice = product.price.replace('$', '');
---

<article class="product-card" itemscope itemtype="https://schema.org/Product">
  <figure>
    {
      product.image ? (
        <img src={product.image} alt={product.imageAlt} itemprop="image" />
      ) : (
        <div class="placeholder" aria-label={product.imageAlt} />
      )
    }
  </figure>
  <div>
    <h2 itemprop="name">{product.name}</h2>
    {product.description && <p itemprop="description">{product.description}</p>}
    <p itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <data value={rawPrice} itemprop="price" aria-label={"Price: " + product.price}>{product.price}</data>
      <meta itemprop="priceCurrency" content="USD" />
    </p>
    <a href={product.paymentLink} rel="noopener" aria-label={`Buy ${product.name} on Stripe`} itemprop="url">Buy {product.name}</a>
  </div>
</article>

<style>
  .product-card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease;
  }

  .product-card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .product-card figure {
    margin: 0;
  }

  .product-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #e5e5e5;
  }

  .product-card > div {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  [itemprop="name"] {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  [itemprop="description"] {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
  }

  [itemprop="offers"] {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: auto;
  }

  [itemprop="url"] {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.625rem 1.25rem;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-align: center;
    transition: background 0.15s ease;
  }

  [itemprop="url"]:hover {
    background: #333;
  }

  [itemprop="url"]:focus-visible {
    outline: 2px solid #1a1a1a;
    outline-offset: 2px;
  }
</style>
