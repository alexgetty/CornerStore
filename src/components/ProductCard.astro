---
interface Product {
  name: string;
  description: string | null;
  image: string | null;
  price: string;
  paymentLink: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article class="card">
  {
    product.image ? (
      <img src={product.image} alt={product.name} class="card-image" />
    ) : (
      <div class="card-image-placeholder" role="img" aria-label={product.name} />
    )
  }
  <div class="card-body">
    <h2 class="card-name">{product.name}</h2>
    {product.description && <p class="card-description">{product.description}</p>}
    <p class="card-price">{product.price}</p>
    <a href={product.paymentLink} class="card-buy">Buy {product.name}</a>
  </div>
</article>

<style>
  .card {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease;
  }

  .card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .card-image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #e5e5e5;
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-name {
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .card-description {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
  }

  .card-price {
    font-size: 1.125rem;
    font-weight: 600;
    color: #1a1a1a;
    margin-top: auto;
  }

  .card-buy {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.625rem 1.25rem;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-align: center;
    transition: background 0.15s ease;
  }

  .card-buy:hover {
    background: #333;
  }

  .card-buy:focus-visible {
    outline: 2px solid #1a1a1a;
    outline-offset: 2px;
  }
</style>
