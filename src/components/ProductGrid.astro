---
import ProductCard from "./ProductCard.astro";
import type { CatalogListing } from "../lib/stripe";

interface Props {
  listings: CatalogListing[];
}

const { listings } = Astro.props;
---

{
  listings.length > 0 ? (
    <div class="grid">
      {listings.map((listing) => (
        <ProductCard listing={listing} />
      ))}
    </div>
  ) : (
    <p class="empty">No products available.</p>
  )
}

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .empty {
    text-align: center;
    color: #777;
    padding: 3rem 1rem;
    font-size: 1.1rem;
  }
</style>
