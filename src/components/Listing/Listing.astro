---
import "./Listing.css";
import type { Listing } from "../../lib/storefront";
import { listingHasPrice, rawPriceToDecimal } from "../../lib/storefront";

interface Props {
  listing: Listing;
}

const { listing } = Astro.props;
const hasPrice = listingHasPrice(listing);
---

<article class="cs-listing" itemscope itemtype="https://schema.org/Product">
  <figure class="cs-listing-image">
    {
      listing.image ? (
        <img src={listing.image} alt={listing.imageAlt} itemprop="image" />
      ) : (
        <div class="cs-listing-placeholder" aria-label={listing.imageAlt} />
      )
    }
  </figure>
  <div class="cs-listing-details">
    <h2 class="cs-listing-name" itemprop="name">{listing.name}</h2>
    {listing.description && <p class="cs-listing-description" itemprop="description">{listing.description}</p>}
    {hasPrice && (
      <p class="cs-listing-price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <data value={String(rawPriceToDecimal(listing.rawPrice!, listing.currency!))} itemprop="price" aria-label={"Price: " + listing.price}>{listing.price}</data>
        <meta itemprop="priceCurrency" content={listing.currency!.toUpperCase()} />
      </p>
    )}
    <a href={listing.paymentLink} class="cs-listing-buy" aria-label={`Buy ${listing.name} on Stripe`} itemprop="url">Buy {listing.name}</a>
  </div>
</article>
