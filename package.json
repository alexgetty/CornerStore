{
  "name": "storefront",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "astro": "^5",
    "stripe": "^20"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9",
    "typescript": "^5",
    "vitest": "^2",
    "@vitest/coverage-v8": "^2"
  }
}
