{
  "name": "corner-store",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "corner-store": "./bin/init.mjs"
  },
  "exports": {
    ".": "./src/lib/storefront/index.ts",
    "./stripe": "./src/lib/stripe/index.ts",
    "./components": "./src/components/index.ts",
    "./layouts/Base": "./src/layouts/Base.astro",
    "./layouts/ContentPage": "./src/layouts/ContentPage.astro",
    "./styles/reset.css": "./src/styles/reset.css",
    "./styles/palette.css": "./src/styles/palette.css",
    "./styles/defaults.css": "./src/styles/defaults.css",
    "./styles/pages/index.css": "./src/styles/pages/index.css"
  },
  "files": [
    "bin/",
    "src/lib/",
    "src/components/",
    "src/layouts/",
    "src/styles/"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.14",
    "gray-matter": "^4.0.3",
    "stripe": "^20"
  },
  "peerDependencies": {
    "astro": "^5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^2",
    "typescript": "^5",
    "vitest": "^2"
  }
}
